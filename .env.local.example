# Copy this file to .env.local and fill in real values for local dev.
# Set the same variables in Vercel project settings for production.
# .env.local is gitignored — never commit your real values.

# Supabase — Project URL is in Project Settings → Data API/API.
# Keys are in Project Settings → API Keys.
# Use the newer Publishable key here, or the legacy anon key from
# "Legacy anon, service_role API keys" if you are using legacy keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-KEY-OR-LEGACY-ANON-KEY

# Owner / admin emails — comma-separated, lowercase. Any signed-in user whose
# email matches one of these gets admin powers (the private Library route
# plus any future admin tools). New owner accounts are created automatically
# on first magic-link sign-in.
OWNER_EMAILS=admin@example.com,admin-alt@example.com

# Supabase secret key — server-only, NEVER prefixed with NEXT_PUBLIC_.
# Used exclusively by /library on the deployed app to read from the private
# `book` Storage bucket after isOwner() passes.
# Use the newer Secret key, or the legacy service_role key from
# "Legacy anon, service_role API keys" if you are using legacy keys.
# Treat this like a database password.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SECRET-KEY-OR-LEGACY-SERVICE-ROLE-KEY
